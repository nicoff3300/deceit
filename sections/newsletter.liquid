<!-- /sections/newsletter.liquid -->
<!-- Sezione newsletter per homepage — stile allineato al popup -->
<!-- Caricare su Shopify: Online Store → Themes → Edit code → Sections → Aggiungi nuova section / sovrascrivi newsletter.liquid -->

{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* === STILE ALLINEATO AL POPUP === */
  .nl-home {
    background: {{ section.settings.bg_color | default: '#F5CDBE' }};
    color: {{ section.settings.text_color | default: '#0A0A0A' }};
    font-family: Helvetica, Arial, sans-serif;
    text-align: center;
    width: 100%;
  }
  .nl-home__inner {
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 1.5rem;
  }
  .nl-home__logo {
    width: 200px;
    height: auto;
    filter: brightness(0);
  }
  .nl-home__heading {
    font-size: 2.188rem;
    font-weight: 400;
    line-height: 1.2;
    margin: 0;
  }
  .nl-home__heading strong {
    font-weight: 700;
  }
  .nl-home__body {
    font-size: 1.5rem;
    line-height: 1.6;
    opacity: .8;
    margin: 0;
  }
  .nl-home .newsletter-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .nl-home .newsletter-form__field-wrapper {
    width: 100%;
  }
  .nl-home .field {
    position: relative;
    width: 100%;
  }
  .nl-home .field__input {
    width: 100%;
    padding: .875rem 1rem;
    background: #fff;
    color: {{ section.settings.text_color | default: '#0A0A0A' }};
    border: none;
    outline: none;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 0;
    box-shadow: none;
    -webkit-appearance: none;
  }
  .nl-home .field__input::placeholder {
    color: #aaa;
  }
  .nl-home .field__label {
    display: none; /* nascondiamo label flottante del tema, usiamo placeholder */
  }
  .nl-home .field:before,
  .nl-home .field:after {
    content: none !important;
  }
  .nl-home .newsletter-form__button {
    display: none; /* nascondiamo il bottone freccia del tema */
  }
  .nl-home .newsletter-form .nl-btn {
    width: 100%;
    padding: 1rem;
    background: {{ section.settings.text_color | default: '#0A0A0A' }};
    color: {{ section.settings.bg_color | default: '#F5CDBE' }};
    border: none;
    font-family: Helvetica, Arial, sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    cursor: pointer;
  }
  .nl-home .newsletter-form .nl-btn:hover {
    background: #00f;
    color: #fff;
  }
  .nl-home .nl-privacy {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    cursor: pointer;
    width: 100%;
    text-align: left;
  }
  .nl-home .nl-privacy input {
    appearance: none;
    -webkit-appearance: none;
    width: 1.25rem;
    height: 1.25rem;
    min-width: 1.25rem;
    border: 2px solid {{ section.settings.text_color | default: '#0A0A0A' }};
    background: #fff;
    cursor: pointer;
    position: relative;
    margin-top: .1rem;
  }
  .nl-home .nl-privacy input:checked {
    background: {{ section.settings.text_color | default: '#0A0A0A' }};
    border-color: {{ section.settings.text_color | default: '#0A0A0A' }};
  }
  .nl-home .nl-privacy input:checked::after {
    content: "✓";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: .875rem;
    font-weight: 700;
    color: {{ section.settings.bg_color | default: '#F5CDBE' }};
    line-height: 1;
  }
  .nl-home .nl-privacy-text {
    font-size: .9rem;
    line-height: 1.5;
    opacity: .7;
  }
  .nl-home .nl-btn {
    margin-top: 1rem;
  }
  .nl-home .nl-privacy-text a {
    text-decoration: underline;
  }
  .nl-home .nl-privacy-error {
    display: none;
    font-size: .6875rem;
    color: #9B2724;
    font-weight: 500;
    margin: -0.5rem 0 0;
    width: 100%;
    text-align: left;
  }
  .nl-home .nl-privacy-error.show {
    display: block;
  }
  .nl-home .newsletter-form__message--success {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.3;
    text-align: center;
    margin: 0;
    color: {{ section.settings.text_color | default: '#0A0A0A' }};
    justify-content: center;
  }
  .nl-home .newsletter-form__message--success svg {
    display: none; /* nascondiamo icona spunta del tema */
  }
{%- endstyle -%}

<div id="nl-home" class="nl-home color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="nl-home__inner">
    {%- if section.settings.show_logo -%}
      <img
        src="https://cdn.shopify.com/s/files/1/0729/7876/0007/files/Logo_deceit_store.svg?v=1768909615"
        alt="DECEIT"
        class="nl-home__logo"
        loading="lazy"
      >
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <p class="nl-home__heading">{{ section.settings.heading }}</p>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <div class="nl-home__body">{{ section.settings.body_text }}</div>
    {%- endif -%}

    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter,discount_10_send">

      <div class="newsletter-form__field-wrapper">
        <div class="field">
          <input
            id="NewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="field__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="Newsletter-error--{{ section.id }}"
            {% endif %}
            placeholder="{{ 'newsletter.label' | t }}"
            required
          >
          <label class="field__label" for="NewsletterForm--{{ section.id }}">
            {{ 'newsletter.label' | t }}
          </label>
          <button type="submit" class="newsletter-form__button field__button" name="commit" aria-label="{{ 'newsletter.button_label' | t }}">
            {% render 'icon-arrow' %}
          </button>
        </div>

        {%- if section.settings.privacy_text != blank -%}
          <label class="nl-privacy" id="nl-privacy-label">
            <input type="checkbox" id="nl-privacy-cb" required>
            <span class="nl-privacy-text">{{ section.settings.privacy_text }}</span>
          </label>
          <p class="nl-privacy-error" id="nl-privacy-err">{{ section.settings.privacy_error }}</p>
        {%- endif -%}

        <button type="submit" class="nl-btn" id="nl-submit">{{ section.settings.button_label | default: 'ISCRIVITI' }}</button>

        {%- if form.errors -%}
          <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
            {%- render 'icon-error' -%}
            {{- form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email -}}
          </small>
        {%- endif -%}
      </div>

      {%- if form.posted_successfully? -%}
        <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>
          {{ section.settings.success_message | default: 'Grazie per esserti iscritto.' }}
        </h3>
      {%- endif -%}
    {% endform %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var cb = document.getElementById('nl-privacy-cb');
    var err = document.getElementById('nl-privacy-err');
    var form = document.querySelector('.nl-home .newsletter-form');
    if (!cb || !form) return;

    // Nascondi errore quando checkbox viene spuntata
    cb.addEventListener('change', function() {
      if (this.checked && err) err.classList.remove('show');
    });

    // Blocca submit se checkbox non spuntata
    form.addEventListener('submit', function(e) {
      if (!cb.checked) {
        e.preventDefault();
        if (err) err.classList.add('show');
      }
    });
  });
</script>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "default": true,
      "label": "Mostra logo"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Iscriviti per ricevere <strong>aggiornamenti su collezioni, eventi e novità esclusive</strong>.",
      "label": "Titolo"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "default": "<p>Lasciaci la tua email per restare aggiornato.</p>",
      "label": "Testo descrittivo"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "ISCRIVITI",
      "label": "Testo del pulsante"
    },
    {
      "type": "inline_richtext",
      "id": "privacy_text",
      "default": "Autorizzo DECEIT al trattamento dei miei dati personali per finalità di marketing e promozione, secondo il D.Lgs. 196/2003 e il Regolamento UE 2016/679 (GDPR). <a href=\"/policies/privacy-policy\" target=\"_blank\">Informativa completa</a>",
      "label": "Testo privacy",
      "info": "Lascia vuoto per nascondere la checkbox GDPR"
    },
    {
      "type": "text",
      "id": "privacy_error",
      "default": "Devi accettare il trattamento dei dati",
      "label": "Messaggio errore privacy"
    },
    {
      "type": "inline_richtext",
      "id": "success_message",
      "default": "Grazie per esserti iscritto.",
      "label": "Messaggio di conferma"
    },
    {
      "type": "header",
      "content": "Colori"
    },
    {
      "type": "color",
      "id": "bg_color",
      "default": "#F5CDBE",
      "label": "Sfondo sezione"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#0A0A0A",
      "label": "Colore testo"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
