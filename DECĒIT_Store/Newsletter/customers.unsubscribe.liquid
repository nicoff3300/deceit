<!-- /templates/customers/unsubscribe.liquid -->
<!-- Caricare su Shopify: Online Store → Themes → Edit code → Templates → Aggiungi nuovo template → customers/unsubscribe -->
{% layout none %}
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DECĒIT — Annulla iscrizione</title>
  <meta name="robots" content="noindex, nofollow">

  {{ content_for_header }}

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F5CDBE;
      --text: #0A0A0A;
      --black: #0A0A0A;
      --blue: #0000FF;
      --white: #FFFFFF;
    }

    html { font-size: 16px; -webkit-font-smoothing: antialiased; }

    body {
      font-family: Helvetica, Arial, sans-serif;
      font-size: 16px;
      line-height: 1.8;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1.5rem 1.25rem;
    }

    .container {
      width: 100%;
      max-width: 480px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 2rem;
      text-align: center;
      animation: fadeIn 0.5s ease;
    }

    .logo {
      width: 200px;
      height: auto;
      filter: brightness(0);
    }

    .title {
      font-size: 2.188rem;
      font-weight: 400;
      line-height: 1.2;
    }

    .title strong {
      font-weight: 700;
    }

    .body {
      font-size: 1rem;
      line-height: 1.6;
      opacity: 0.8;
    }

    /* ===== BOTTONI ===== */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      padding: 1rem;
      background: var(--black);
      color: var(--bg);
      border: 2px solid var(--black);
      font-family: Helvetica, Arial, sans-serif;
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .btn:hover {
      background: var(--blue);
      color: var(--white);
      border-color: var(--blue);
    }

    .btn--outline {
      background: transparent;
      color: var(--black);
    }

    .btn--outline:hover {
      background: var(--black);
      color: var(--bg);
      border-color: var(--black);
    }

    .btn-group {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .footer-text {
      font-size: 0.8125rem;
      opacity: 0.65;
      line-height: 1.5;
    }

    .footer-text a {
      color: var(--text);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .spacer {
      height: 1rem;
    }

    /* ===== CONFERMA NASCOSTA ===== */
    .screen-confirm {
      display: none;
    }
    .screen-confirm.active {
      display: flex;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>

{% form 'customer_unsubscribe' %}
  {% if form.posted_successfully? %}
    <!-- ============ CONFERMA ============ -->
    <div class="container screen-confirm active">
      <img src="https://cdn.shopify.com/s/files/1/0729/7876/0007/files/Logo_deceit_store.svg?v=1768909615" alt="DECĒIT" class="logo">

      <div class="title">
        Iscrizione <strong>cancellata</strong>.
      </div>

      <div class="body">
        Non riceverai più email di marketing da DECĒIT.
        Puoi sempre iscriverti di nuovo in qualsiasi momento.
      </div>

      <a href="/" class="btn">Torna alla homepage</a>

      <div class="footer-text">
        Decēit — dailywear for people who struggle with the truth.
      </div>
    </div>

  {% else %}
    <!-- ============ SEI SICURO? ============ -->
    <div class="container" id="confirmStep">
      <img src="https://cdn.shopify.com/s/files/1/0729/7876/0007/files/Logo_deceit_store.svg?v=1768909615" alt="DECĒIT" class="logo">

      <div class="title">
        Sei sicuro di voler <strong>cancellare l'iscrizione</strong>?
      </div>

      <div class="body">
        Non riceverai più aggiornamenti su nuove collezioni, eventi e novità esclusive DECĒIT.
      </div>

      <div class="btn-group">
        <button type="submit" class="btn" id="confirmBtn">Sì, cancella iscrizione</button>
        <a href="/" class="btn btn--outline">No, rimani iscritto</a>
      </div>

      <div class="footer-text">
        Decēit — dailywear for people who struggle with the truth.
      </div>
    </div>
  {% endif %}
{% endform %}

<script>
  // Se il form viene inviato, mostra stato loading
  document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('confirmBtn');
    var form = btn && btn.closest('form');
    if (btn && form) {
      form.addEventListener('submit', function() {
        btn.textContent = 'Cancellazione in corso…';
        btn.disabled = true;
      });
    }
  });
</script>

</body>
</html>
