{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="newsletter center {% if section.settings.full_width == false %}newsletter--narrow page-width{% endif %}">
  <div class="newsletter__wrapper color-{{ section.settings.color_scheme }} gradient content-container isolate{% if section.settings.full_width %} content-container--full-width{% endif %} section-{{ section.id }}-padding">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {% render block %}
        {%- when 'heading' -%}
          <h2
            class="inline-richtext {{ block.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {{ block.settings.heading }}
          </h2>
        {%- when 'paragraph' -%}
          <div
            class="newsletter__subheading rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
          >
            {{ block.settings.text }}
          </div>
        {%- when 'email_form' -%}
          <div {{ block.shopify_attributes }}>
            {% form 'customer', class: 'newsletter-form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">

              <!-- Honeypot anti-spam Mailchimp (deve restare vuoto) -->
              <div style="position: absolute; left: -5000px;" aria-hidden="true">
                <input type="text" name="b_cf64b003a19979e390b9855e1_e332a30c5d" tabindex="-1" autocomplete="off">
              </div>

              <div
                class="newsletter-form__field-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                <div class="field">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="field__input"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="Newsletter-error--{{ section.id }}"
                    {% endif %}
                    placeholder="{{ 'newsletter.label' | t }}"
                    required
                  >
                  <label class="field__label" for="NewsletterForm--{{ section.id }}">
                    {{ 'newsletter.label' | t }}
                  </label>
                  <button
                    type="submit"
                    class="newsletter-form__button field__button"
                    name="commit"
                    id="Subscribe"
                    aria-label="{{ 'newsletter.button_label' | t }}"
                  >
                    {% render 'icon-arrow' %}
                  </button>
                </div>
                
                {%- if block.settings.privacy_text != blank -%}
                <div class="newsletter-privacy-container" style="margin-top: 12px; margin-bottom: 5px; display: flex; align-items: center; justify-content: flex-start; gap: 8px; text-align: left;">
                  <input type="checkbox" id="newsletter-privacy">
                  <label for="newsletter-privacy" style="font-size: 1.2rem; cursor: pointer; line-height: 1.3; margin: 0;">
                    {{ block.settings.privacy_text }}
                  </label>
                </div>
                <p id="newsletter-privacy-error" style="display: none; color: #d20000; font-size: 1.2rem; margin: 0 0 10px 0; text-align: center;">
                  {{ block.settings.privacy_error }}
                </p>
                {%- endif -%}

                {%- if form.errors -%}
                  <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                    {%- render 'icon-error' -%}
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </small>
                {%- endif -%}
              </div>
              {%- if form.posted_successfully? -%}
                <h3
                  class="newsletter-form__message newsletter-form__message--success form__message"
                  id="Newsletter-success--{{ section.id }}"
                  tabindex="-1"
                  autofocus
                >
                  {% render 'icon-success' -%}
                  {{- 'newsletter.success' | t }}
                </h3>
              {%- endif -%}
            {% endform %}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

<!-- POPUP DOPO ISCRIZIONE NEWSLETTER -->
<div id="nl-popup-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:9999; align-items:center; justify-content:center;">
  <div id="nl-popup" style="position:relative; background:#F5CDBE; color:#17453C; width:min(90vw, 480px); aspect-ratio:1080/1350; max-height:90vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; font-family:inherit; padding:2rem;">
    <button id="nl-popup-close" style="position:absolute; top:1rem; right:1rem; background:none; border:none; color:#17453C; font-size:clamp(1.5rem, 5vw, 2rem); cursor:pointer; line-height:1; padding:0.5rem; min-width:44px; min-height:44px; display:flex; align-items:center; justify-content:center;">✕</button>
    <p style="font-size:clamp(1.5rem, 6vw, 4.9rem); font-weight:700; line-height:1.3; margin:0 5% 1.5%; text-transform:uppercase; letter-spacing:0.02em;">Grazie per esserti iscritto</p>
    <p style="font-size:clamp(1.5rem, 4.2vw, 2.3rem); margin:0 5%; line-height:1.4; font-weight:400;">Abbiamo inviato il tuo codice sconto a <strong id="nl-popup-email"></strong></p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var privacyCheckbox = document.getElementById('newsletter-privacy');
    var form = document.querySelector('.newsletter-form');
    if (!form) return;

    var submitBtn = form.querySelector('button[type="submit"]');
    var errorText = document.getElementById('newsletter-privacy-error');

    // ===== MAILCHIMP CONFIG =====
    var MC_DC = 'us21';
    var MC_U = 'cf64b003a19979e390b9855e1';
    var MC_ID = 'e332a30c5d';
    var MC_TAGS = '3015386'; // homepage-newsletter

    // ===== GDPR CHECK =====
    privacyCheckbox.addEventListener('change', function() {
      if (this.checked && errorText) {
        errorText.style.display = 'none';
      }
    });

    // ===== Mailchimp JSONP + Shopify native submit =====
    // Click handler: GDPR check + Mailchimp JSONP fire-and-forget
    if (submitBtn) {
      submitBtn.addEventListener('click', function(e) {
        if (privacyCheckbox && !privacyCheckbox.checked) {
          e.preventDefault();
          if (errorText) errorText.style.display = 'block';
          return;
        }
        if (errorText) errorText.style.display = 'none';

        var emailInput = form.querySelector('input[name="contact[email]"]');
        var email = emailInput ? emailInput.value.trim() : '';

        // Salva email in localStorage per il popup dopo reload
        if (email) {
          try { localStorage.setItem('nl_submitted_email', email); } catch(e) {}
        }

        // Mailchimp JSONP — fire-and-forget
        if (email) {
          var params = 'u=' + MC_U +
            '&id=' + MC_ID +
            '&EMAIL=' + encodeURIComponent(email) +
            '&tags=' + encodeURIComponent(MC_TAGS) +
            '&b_' + MC_U + '_' + MC_ID + '=';

          var url = 'https://' + MC_DC + '.list-manage.com/subscribe/post-json?' + params;
          var callbackName = 'mcCallback_' + Date.now();

          window[callbackName] = function() {
            delete window[callbackName];
            if (script.parentNode) script.parentNode.removeChild(script);
          };

          var script = document.createElement('script');
          script.src = url + '&c=' + callbackName;
          script.onerror = function() {
            delete window[callbackName];
            if (script.parentNode) script.parentNode.removeChild(script);
          };
          document.body.appendChild(script);
        }
      });
    }

    // GDPR: blocca anche Enter-key submit
    form.addEventListener('submit', function(e) {
      if (privacyCheckbox && !privacyCheckbox.checked) {
        e.preventDefault();
        if (errorText) errorText.style.display = 'block';
      }
    });

    // ===== POPUP DOPO ISCRIZIONE =====
    if (window.location.search.indexOf('customer_posted=true') !== -1) {
      var savedEmail = '';
      try { savedEmail = localStorage.getItem('nl_submitted_email') || ''; } catch(e) {}

      if (savedEmail) {
        var popupOverlay = document.getElementById('nl-popup-overlay');
        var popupEmail = document.getElementById('nl-popup-email');
        var popupClose = document.getElementById('nl-popup-close');
        if (popupOverlay) {
          popupEmail.textContent = savedEmail;
          popupOverlay.style.display = 'flex';
          popupClose.addEventListener('click', function() {
            popupOverlay.style.display = 'none';
          });
          popupOverlay.addEventListener('click', function(e) {
            if (e.target === popupOverlay) popupOverlay.style.display = 'none';
          });
        }
      }
      try { localStorage.removeItem('nl_submitted_email'); } catch(e) {}
    }
  });
</script>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": true,
      "label": "t:sections.newsletter.settings.full_width.label"
    },
    {
      "type": "paragraph",
      "content": "t:sections.newsletter.settings.paragraph.content"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.newsletter.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Subscribe to our emails",
          "label": "t:sections.newsletter.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options__1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options__2.label"
            },
            {
              "value": "h0",
              "label": "t:sections.all.heading_size.options__3.label"
            }
          ],
          "default": "h1",
          "label": "t:sections.all.heading_size.label"
        }
      ]
    },
    {
      "type": "paragraph",
      "name": "t:sections.newsletter.blocks.paragraph.name",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Be the first to know about new collections and exclusive offers.</p>",
          "label": "t:sections.newsletter.blocks.paragraph.settings.paragraph.label"
        }
      ]
    },
    {
      "type": "email_form",
      "name": "t:sections.newsletter.blocks.email_form.name",
      "limit": 1,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "privacy_text",
          "default": "I have read and agree to the <a href=\"/policies/privacy-policy\" target=\"_blank\">Privacy Policy</a>",
          "info": "Leave blank to disable and hide the mandatory checkbox.",
          "label": "Privacy Policy text"
        },
        {
          "type": "text",
          "id": "privacy_error",
          "default": "You must agree to the Privacy Policy to subscribe to the newsletter.",
          "label": "Privacy error message"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter.presets.name",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "paragraph"
        },
        {
          "type": "email_form"
        }
      ]
    }
  ]
}
{% endschema %}